# Database Connection
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<dbname>?sslmode=require"
DB_SSLMODE="require"

# Groq AI
GROQ_API_KEY=<your_groq_api_key>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Firebase — provide EITHER a path to the JSON file OR the JSON string
GOOGLE_APPLICATION_CREDENTIALS=config/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...",...}'

# Stripe
STRIPE_SECRET_KEY=<your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>
STRIPE_PRICE_PRO=<your_stripe_price_id_pro>
STRIPE_PRICE_ELITE=<your_stripe_price_id_elite>
FRONTEND_URL=http://localhost:3000
